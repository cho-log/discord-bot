# cho-log Discord Bot 환경변수
# 사용법: cp .env.example .env  (또는 GitHub Actions secrets.DOTENV에 등록)
#
# 마이그레이션 진행 중이라 실제 봇 기능 코드(#5~#8)에서 사용될 변수만 적혀있다.
# 신규 변수 추가 시 이 파일도 함께 갱신할 것.

# === Discord ===
# Discord Developer Portal에서 발급한 봇 토큰
DISCORD_BOT_TOKEN=

# 알림이 송출될 Discord 길드(서버) ID
DISCORD_GUILD_ID=

# PR 머지 알림 채널 ID
DISCORD_PR_MERGE_CHANNEL_ID=

# === GitHub ===
# repo + read:org 스코프가 있는 PAT 또는 GitHub App 토큰
GITHUB_TOKEN=

# GitHub REST API 버전 (예: 2022-11-28)
GITHUB_API_VERSION=2022-11-28

# === PR 머지 알림 필터 ===
# 콤마 구분 (예: cho-log,jaeyeonling)
ALLOW_ORGANIZATIONS=cho-log

# 콤마 구분 (예: discord-bot,docs). 비우면 전체 허용
ALLOW_REPOSITORIES=

# 콤마 구분 (예: main,master). 매치되면 알림 제외
DISALLOW_BRANCHES=main,master

# === 런타임 ===
# 로그 레벨: trace | debug | info | warn | error
LOG_LEVEL=info

# Node 환경: development | production
NODE_ENV=production
